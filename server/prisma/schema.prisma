generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Plan {
  STARTER
  BASIC
  PREMIUM
}

enum SubscriptionStatus {
  ACTIVE
  TRIAL
  PAST_DUE
  CANCELED
}

enum BillingCycle {
  MONTHLY
  ANNUAL
}

enum UserRole {
  SUPERADMIN
  ADMIN
  USER
}

enum OrderStatus {
  DRAFT
  PAID
  PARTIAL
  CANCELED
}

enum PaymentMethod {
  CASH
  CARD
  MOBILE_MONEY
  TRANSFER
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
}

enum NotificationType {
  INFO
  WARNING
  SUCCESS
  ERROR
}

enum UnitType {
  DOSAGE
  SALE
  STOCK
}

enum ProductKind {
  ARTICLE
  COMPONENT
}

enum StorageZoneType {
  WAREHOUSE
  STORE
  COUNTER
}

enum SupplyRequestStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
  PARTIAL
  FULFILLED
  CANCELED
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum TransferStatus {
  DRAFT
  IN_TRANSIT
  COMPLETED
  CANCELED
}

enum PurchaseRequestStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
  ORDERED
  CANCELED
}

enum PurchaseOrderStatus {
  DRAFT
  SENT
  PARTIAL
  COMPLETED
  CANCELED
}

enum DeliveryNoteStatus {
  PENDING
  RECEIVED
  PARTIAL
  CANCELED
}

enum StockEntryStatus {
  PENDING
  APPROVED
  POSTED
  REJECTED
}

enum StockEntrySource {
  DIRECT
  PURCHASE_ORDER
  TRANSFER
}

enum InventoryMovementType {
  IN
  OUT
  TRANSFER_IN
  TRANSFER_OUT
  ADJUSTMENT
}
model Tenant {
  id            String         @id @default(cuid())
  name          String
  ownerId       String?
  primaryCurrencyCode String   @default("USD")
  secondaryCurrencyCode String?
  exchangeRate  Decimal?       @db.Decimal(18, 6)
  subscription  Subscription?
  users         User[]
  stores        Store[]
  products      Product[]
  units         UnitOfMeasure[]
  productComponents ProductComponent[]
  productUnitConversions ProductUnitConversion[]
  approvalFlowSteps ApprovalFlowStep[]
  customers     Customer[]
  categories    ProductCategory[]
  families      ProductFamily[]
  orders        Order[]
  wishlists     Wishlist[]
  storageZones  StorageZone[]
  suppliers     Supplier[]
  payments      Payment[]
  supplyRequests    SupplyRequest[]
  supplyRequestItems SupplyRequestItem[]
  supplyRequestApprovals SupplyRequestApproval[]
  approvalFlows     ApprovalFlow[]
  productTransfers  ProductTransfer[]
  productTransferItems ProductTransferItem[]
  purchaseRequests  PurchaseRequest[]
  purchaseRequestItems PurchaseRequestItem[]
  purchaseRequestApprovals PurchaseRequestApproval[]
  purchaseOrders    PurchaseOrder[]
  purchaseOrderItems PurchaseOrderItem[]
  deliveryNotes     DeliveryNote[]
  deliveryNoteItems DeliveryNoteItem[]
  stockEntries      StockEntry[]
  stockEntryItems   StockEntryItem[]
  inventoryMovements InventoryMovement[]
  inventory         Inventory[]
  bonusRecords      BonusRecord[]
  invoices          Invoice[]
  bills             Bill[]
  sponsorships      Sponsorship[]
  auditLogs         AuditLog[]
  messages          Message[]
  notifications     Notification[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@map("tenants")
}

model Subscription {
  id         String             @id @default(cuid())
  tenantId   String             @unique
  plan       Plan
  billingCycle BillingCycle     @default(MONTHLY)
  price      Decimal            @db.Decimal(10, 2)
  status     SubscriptionStatus @default(ACTIVE)
  startedAt  DateTime           @default(now())
  endsAt     DateTime?
  warn7At    DateTime?
  warn3At    DateTime?
  warn1At    DateTime?
  warn0At    DateTime?
  postExpiredAt DateTime?
  remindersEnabled Boolean      @default(true)
  maxStores  Int
  maxUsers   Int
  tenant     Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt

  @@map("subscripion")
}

model User {
  id                      String         @id @default(cuid())
  tenantId                String
  storeId                 String?
  defaultStorageZoneId    String?
  firstName               String?
  lastName                String?
  email                   String?        @unique
  phone                   String?        @unique
  passwordHash            String?
  role                    UserRole       @default(USER)
  mustChangePassword      Boolean        @default(false)
  twoFactorEnabled        Boolean        @default(false)
  twoFactorSecret         String?
  googleId                String?
  isActive                Boolean        @default(true)
  resetPasswordToken      String?
  resetPasswordExpiresAt  DateTime?
  lastLoginAt             DateTime?
  createdAt               DateTime       @default(now())
  updatedAt               DateTime       @updatedAt

  tenant        Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  store         Store?     @relation(fields: [storeId], references: [id])
  defaultStorageZone StorageZone? @relation("UserDefaultStorageZone", fields: [defaultStorageZoneId], references: [id])
  sessions      AuthSession[]
  permissions   UserPermission[]
  orders        Order[]    @relation("UserOrders")
  messagesSent  Message[]  @relation("MessageSender")
  messagesRecv  Message[]  @relation("MessageRecipient")
  notifications Notification[]
  auditLogs     AuditLog[]
  stockEntriesCreated StockEntry[] @relation("StockEntryCreatedBy")
  stockEntriesApproved StockEntry[] @relation("StockEntryApprovedBy")
  supplyRequestsRequested SupplyRequest[] @relation("SupplyRequestRequestedBy")
  supplyRequestApprovals SupplyRequestApproval[] @relation("SupplyRequestApprover")
  purchaseRequestsRequested PurchaseRequest[] @relation("PurchaseRequestRequestedBy")
  purchaseRequestApprovals PurchaseRequestApproval[] @relation("PurchaseRequestApprover")
  purchaseOrdersOrdered PurchaseOrder[] @relation("PurchaseOrderOrderedBy")
  deliveryNotesReceived DeliveryNote[] @relation("DeliveryNoteReceivedBy")
  approvalFlowSteps ApprovalFlowStep[] @relation("ApprovalFlowApprover")
  productTransfersRequested ProductTransfer[] @relation("ProductTransferRequestedBy")
  inventoryMovementsCreated InventoryMovement[] @relation("InventoryMovementCreatedBy")

  @@index([tenantId])
  @@map("users")
}

model Permission {
  id          String           @id @default(cuid())
  code        String           @unique
  label       String
  description String?
  users       UserPermission[]

  @@map("permissions")
}

model UserPermission {
  id           String      @id @default(cuid())
  userId       String
  permissionId String
  createdAt    DateTime    @default(now())
  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  permission   Permission  @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([userId, permissionId])
  @@map("user_permissions")
}

model AuthSession {
  id               String   @id @default(cuid())
  userId           String
  refreshTokenHash String
  expiresAt        DateTime
  createdAt        DateTime @default(now())
  lastUsedAt       DateTime?
  revokedAt        DateTime?
  ip               String?
  userAgent        String?
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("auth_sessions")
}

model Store {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  code        String?
  addressLine String?
  commune     String?
  city        String?
  country     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  users       User[]
  orders      Order[]
  storageZones StorageZone[]
  inventory   Inventory[]
  supplyRequests SupplyRequest[]
  purchaseRequests PurchaseRequest[]
  purchaseOrders PurchaseOrder[]
  stockEntries  StockEntry[]
  productTransfersFrom ProductTransfer[] @relation("TransferFrom")
  productTransfersTo   ProductTransfer[] @relation("TransferTo")

  @@index([tenantId])
  @@map("stores")
}

model ProductCategory {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  products  Product[]

  @@index([tenantId])
  @@map("productCategories")
}

model ProductFamily {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  products  Product[]

  @@index([tenantId])
  @@map("productFamilies")
}

model UnitOfMeasure {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  type      UnitType
  symbol    String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant         Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  saleProducts   Product[] @relation("SaleUnit")
  stockProducts  Product[] @relation("StockUnit")
  dosageProducts Product[] @relation("DosageUnit")
  componentDosage ProductComponent[] @relation("DosageUnitComponent")
  fromConversions ProductUnitConversion[] @relation("FromUnit")
  toConversions   ProductUnitConversion[] @relation("ToUnit")
  supplyRequestItems SupplyRequestItem[]
  productTransferItems ProductTransferItem[]
  purchaseRequestItems PurchaseRequestItem[]
  purchaseOrderItems PurchaseOrderItem[]
  deliveryNoteItems DeliveryNoteItem[]
  stockEntryItems StockEntryItem[]

  @@index([tenantId])
  @@map("units")
}

model ProductComponent {
  id                String   @id @default(cuid())
  tenantId          String
  productId         String
  componentProductId String?
  componentName     String?
  dosageUnitId      String?
  quantity          Decimal  @db.Decimal(12, 4)
  createdAt         DateTime @default(now())

  tenant          Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  product         Product @relation("ProductComponents", fields: [productId], references: [id], onDelete: Cascade)
  componentProduct Product? @relation("ComponentProduct", fields: [componentProductId], references: [id])
  dosageUnit      UnitOfMeasure? @relation("DosageUnitComponent", fields: [dosageUnitId], references: [id])

  @@index([tenantId])
  @@index([productId])
  @@map("productComponents")
}

model ProductUnitConversion {
  id         String   @id @default(cuid())
  tenantId   String
  productId  String
  fromUnitId String
  toUnitId   String
  factor     Decimal  @db.Decimal(12, 6)
  createdAt  DateTime @default(now())

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  fromUnit UnitOfMeasure @relation("FromUnit", fields: [fromUnitId], references: [id])
  toUnit   UnitOfMeasure @relation("ToUnit", fields: [toUnitId], references: [id])

  @@unique([productId, fromUnitId, toUnitId])
  @@index([tenantId])
  @@map("productUnitConversions")
}

model Product {
  id          String   @id @default(cuid())
  tenantId    String
  categoryId  String?
  familyId    String?
  saleUnitId  String?
  stockUnitId String?
  dosageUnitId String?
  kind        ProductKind @default(ARTICLE)
  sku         String?  @unique
  name        String
  description String?
  unitPrice   Decimal  @db.Decimal(10, 2)
  currencyCode String  @default("USD")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  category    ProductCategory? @relation(fields: [categoryId], references: [id])
  family      ProductFamily?   @relation(fields: [familyId], references: [id])
  saleUnit    UnitOfMeasure?   @relation("SaleUnit", fields: [saleUnitId], references: [id])
  stockUnit   UnitOfMeasure?   @relation("StockUnit", fields: [stockUnitId], references: [id])
  dosageUnit  UnitOfMeasure?   @relation("DosageUnit", fields: [dosageUnitId], references: [id])
  inventory   Inventory[]
  orderItems  OrderItem[]
  wishlists   Wishlist[]
  components  ProductComponent[] @relation("ProductComponents")
  usedInComponents ProductComponent[] @relation("ComponentProduct")
  unitConversions ProductUnitConversion[]
  supplyRequestItems SupplyRequestItem[]
  productTransferItems ProductTransferItem[]
  purchaseRequestItems PurchaseRequestItem[]
  purchaseOrderItems PurchaseOrderItem[]
  deliveryNoteItems DeliveryNoteItem[]
  stockEntryItems StockEntryItem[]
  inventoryMovements InventoryMovement[]

  @@index([tenantId])
  @@index([tenantId, kind])
  @@map("products")
}

model Customer {
  id        String   @id @default(cuid())
  tenantId  String
  code      String?
  firstName String?
  lastName  String?
  phone     String?
  email     String?
  addressLine String?
  commune   String?
  city      String?
  country   String?
  points    Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant      Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  orders      Order[]
  wishlists   Wishlist[]
  bonusRecord BonusRecord[]
  sponsorships Sponsorship[] @relation("Sponsor")
  sponsoredBy Sponsorship?   @relation("Sponsored")

  @@index([tenantId])
  @@map("customers")
}

model Order {
  id          String      @id @default(cuid())
  tenantId    String
  storeId     String?
  customerId  String?
  createdById String?
  status      OrderStatus @default(DRAFT)
  subtotal    Decimal     @db.Decimal(10, 2)
  tax         Decimal     @db.Decimal(10, 2)
  total       Decimal     @db.Decimal(10, 2)
  currencyCode String     @default("USD")
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  tenant      Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  store       Store?      @relation(fields: [storeId], references: [id])
  customer    Customer?   @relation(fields: [customerId], references: [id])
  createdBy   User?       @relation("UserOrders", fields: [createdById], references: [id])
  items       OrderItem[]
  payments    Payment[]
  invoices    Invoice[]

  @@index([tenantId])
  @@map("orders")
}

model OrderItem {
  id        String   @id @default(cuid())
  orderId   String
  productId String
  quantity  Int
  unitPrice Decimal  @db.Decimal(10, 2)
  total     Decimal  @db.Decimal(10, 2)
  currencyCode String @default("USD")

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@map("order_items")
}

model Wishlist {
  id         String   @id @default(cuid())
  tenantId   String
  customerId String?
  productId  String
  createdAt  DateTime @default(now())

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer Customer? @relation(fields: [customerId], references: [id])
  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("wishlists")
}

model StorageZone {
  id        String   @id @default(cuid())
  tenantId  String
  storeId   String?
  name      String
  code      String?
  zoneType  StorageZoneType @default(STORE)
  note      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  store  Store?  @relation(fields: [storeId], references: [id])
  defaultUsers User[] @relation("UserDefaultStorageZone")
  inventory Inventory[]
  supplyRequests SupplyRequest[]
  transfersFrom ProductTransfer[] @relation("TransferFromZone")
  transfersTo   ProductTransfer[] @relation("TransferToZone")
  stockEntries  StockEntry[]
  movements     InventoryMovement[]

  @@index([tenantId])
  @@map("storageZone")
}

model Supplier {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  email     String?
  phone     String?
  addressLine String?
  city      String?
  country   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  purchaseOrders PurchaseOrder[]
  deliveryNotes  DeliveryNote[]

  @@index([tenantId])
  @@map("suppliers")
}

model ApprovalFlow {
  id        String   @id @default(cuid())
  tenantId  String
  code      String
  name      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  steps  ApprovalFlowStep[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@map("approvalFlows")
}

model ApprovalFlowStep {
  id        String   @id @default(cuid())
  tenantId  String
  flowId    String
  stepOrder Int
  approverRole UserRole?
  approverUserId String?
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  flow   ApprovalFlow @relation(fields: [flowId], references: [id], onDelete: Cascade)
  approver User? @relation("ApprovalFlowApprover", fields: [approverUserId], references: [id])

  @@index([tenantId])
  @@index([flowId])
  @@map("approvalFlowSteps")
}

model Payment {
  id        String        @id @default(cuid())
  tenantId  String
  orderId   String
  amount    Decimal       @db.Decimal(10, 2)
  currencyCode String     @default("USD")
  method    PaymentMethod
  status    PaymentStatus @default(PENDING)
  reference String?
  paidAt    DateTime?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  order  Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("payements")
}

model SupplyRequest {
  id          String   @id @default(cuid())
  tenantId    String
  storeId     String?
  storageZoneId String?
  title       String
  status      SupplyRequestStatus @default(DRAFT)
  requestedById String?
  note        String?
  pdfData     Bytes?
  pdfFileName String?
  pdfGeneratedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  store  Store? @relation(fields: [storeId], references: [id])
  storageZone StorageZone? @relation(fields: [storageZoneId], references: [id])
  requestedBy User? @relation("SupplyRequestRequestedBy", fields: [requestedById], references: [id])
  items  SupplyRequestItem[]
  approvals SupplyRequestApproval[]
  purchaseRequests PurchaseRequest[]

  @@index([tenantId])
  @@map("supplyRequests")
}

model SupplyRequestItem {
  id        String   @id @default(cuid())
  tenantId  String
  supplyRequestId String
  productId String
  unitId    String?
  quantity  Decimal  @db.Decimal(12, 4)
  note      String?
  createdAt DateTime @default(now())

  tenant        Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  supplyRequest SupplyRequest @relation(fields: [supplyRequestId], references: [id], onDelete: Cascade)
  product       Product      @relation(fields: [productId], references: [id])
  unit          UnitOfMeasure? @relation(fields: [unitId], references: [id])

  @@index([tenantId])
  @@index([supplyRequestId])
  @@map("supplyRequestItems")
}

model SupplyRequestApproval {
  id        String   @id @default(cuid())
  tenantId  String
  supplyRequestId String
  stepOrder Int
  approverId String?
  approverRole UserRole?
  status    ApprovalStatus @default(PENDING)
  decidedAt DateTime?
  note      String?

  tenant        Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  supplyRequest SupplyRequest @relation(fields: [supplyRequestId], references: [id], onDelete: Cascade)
  approver      User?        @relation("SupplyRequestApprover", fields: [approverId], references: [id])

  @@index([tenantId])
  @@index([supplyRequestId])
  @@map("supplyRequestApprovals")
}

model ProductTransfer {
  id          String   @id @default(cuid())
  tenantId    String
  fromStoreId String
  toStoreId   String
  fromZoneId  String?
  toZoneId    String?
  requestedById String?
  status      TransferStatus @default(DRAFT)
  note        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant    Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  fromStore Store  @relation("TransferFrom", fields: [fromStoreId], references: [id])
  toStore   Store  @relation("TransferTo", fields: [toStoreId], references: [id])
  fromZone  StorageZone? @relation("TransferFromZone", fields: [fromZoneId], references: [id])
  toZone    StorageZone? @relation("TransferToZone", fields: [toZoneId], references: [id])
  requestedBy User? @relation("ProductTransferRequestedBy", fields: [requestedById], references: [id])
  items     ProductTransferItem[]

  @@index([tenantId])
  @@map("productTransferts")
}

model ProductTransferItem {
  id        String   @id @default(cuid())
  tenantId  String
  transferId String
  productId String
  unitId    String?
  quantity  Decimal  @db.Decimal(12, 4)
  createdAt DateTime @default(now())

  tenant    Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  transfer  ProductTransfer @relation(fields: [transferId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id])
  unit      UnitOfMeasure? @relation(fields: [unitId], references: [id])

  @@index([tenantId])
  @@index([transferId])
  @@map("productTransferItems")
}

model PurchaseRequest {
  id        String   @id @default(cuid())
  tenantId  String
  storeId   String?
  supplyRequestId String?
  requestedById String?
  title     String
  status    PurchaseRequestStatus @default(DRAFT)
  note      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  store  Store? @relation(fields: [storeId], references: [id])
  supplyRequest SupplyRequest? @relation(fields: [supplyRequestId], references: [id])
  requestedBy User? @relation("PurchaseRequestRequestedBy", fields: [requestedById], references: [id])
  items  PurchaseRequestItem[]
  approvals PurchaseRequestApproval[]
  purchaseOrders PurchaseOrder[]

  @@index([tenantId])
  @@map("purchaseRequests")
}

model PurchaseRequestItem {
  id        String   @id @default(cuid())
  tenantId  String
  purchaseRequestId String
  productId String
  unitId    String?
  quantity  Decimal  @db.Decimal(12, 4)
  note      String?
  createdAt DateTime @default(now())

  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  purchaseRequest PurchaseRequest @relation(fields: [purchaseRequestId], references: [id], onDelete: Cascade)
  product  Product @relation(fields: [productId], references: [id])
  unit     UnitOfMeasure? @relation(fields: [unitId], references: [id])

  @@index([tenantId])
  @@index([purchaseRequestId])
  @@map("purchaseRequestItems")
}

model PurchaseRequestApproval {
  id        String   @id @default(cuid())
  tenantId  String
  purchaseRequestId String
  stepOrder Int
  approverId String?
  approverRole UserRole?
  status    ApprovalStatus @default(PENDING)
  decidedAt DateTime?
  note      String?

  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  purchaseRequest PurchaseRequest @relation(fields: [purchaseRequestId], references: [id], onDelete: Cascade)
  approver User? @relation("PurchaseRequestApprover", fields: [approverId], references: [id])

  @@index([tenantId])
  @@index([purchaseRequestId])
  @@map("purchaseRequestApprovals")
}

model PurchaseOrder {
  id        String   @id @default(cuid())
  tenantId  String
  storeId   String?
  supplierId String?
  purchaseRequestId String?
  orderedById String?
  code      String?
  status    PurchaseOrderStatus @default(DRAFT)
  orderDate DateTime @default(now())
  expectedDate DateTime?
  note      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  store  Store? @relation(fields: [storeId], references: [id])
  supplier Supplier? @relation(fields: [supplierId], references: [id])
  purchaseRequest PurchaseRequest? @relation(fields: [purchaseRequestId], references: [id])
  orderedBy User? @relation("PurchaseOrderOrderedBy", fields: [orderedById], references: [id])
  items PurchaseOrderItem[]
  deliveryNotes DeliveryNote[]

  @@index([tenantId])
  @@map("purchaseOrders")
}

model PurchaseOrderItem {
  id        String   @id @default(cuid())
  tenantId  String
  purchaseOrderId String
  productId String
  unitId    String?
  quantity  Decimal  @db.Decimal(12, 4)
  unitPrice Decimal? @db.Decimal(12, 4)
  currencyCode String @default("USD")
  createdAt DateTime @default(now())

  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  product  Product @relation(fields: [productId], references: [id])
  unit     UnitOfMeasure? @relation(fields: [unitId], references: [id])

  @@index([tenantId])
  @@index([purchaseOrderId])
  @@map("purchaseOrderItems")
}

model DeliveryNote {
  id        String   @id @default(cuid())
  tenantId  String
  supplierId String?
  purchaseOrderId String?
  receivedById String?
  code      String?
  status    DeliveryNoteStatus @default(PENDING)
  receivedAt DateTime?
  note      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  supplier Supplier? @relation(fields: [supplierId], references: [id])
  purchaseOrder PurchaseOrder? @relation(fields: [purchaseOrderId], references: [id])
  receivedBy User? @relation("DeliveryNoteReceivedBy", fields: [receivedById], references: [id])
  items DeliveryNoteItem[]

  @@index([tenantId])
  @@map("deliveryNotes")
}

model DeliveryNoteItem {
  id        String   @id @default(cuid())
  tenantId  String
  deliveryNoteId String
  productId String
  unitId    String?
  orderedQty Decimal? @db.Decimal(12, 4)
  deliveredQty Decimal @db.Decimal(12, 4)
  createdAt DateTime @default(now())

  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  deliveryNote DeliveryNote @relation(fields: [deliveryNoteId], references: [id], onDelete: Cascade)
  product  Product @relation(fields: [productId], references: [id])
  unit     UnitOfMeasure? @relation(fields: [unitId], references: [id])

  @@index([tenantId])
  @@index([deliveryNoteId])
  @@map("deliveryNoteItems")
}

model Inventory {
  id        String   @id @default(cuid())
  tenantId  String
  storeId   String
  storageZoneId String
  productId String
  quantity  Int      @default(0)
  minLevel  Int      @default(0)
  updatedAt DateTime @updatedAt

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  store   Store   @relation(fields: [storeId], references: [id])
  storageZone StorageZone @relation(fields: [storageZoneId], references: [id])
  product Product @relation(fields: [productId], references: [id])

  @@unique([storageZoneId, productId])
  @@index([tenantId])
  @@map("inventory")
}

model StockEntry {
  id        String   @id @default(cuid())
  tenantId  String
  sourceType StockEntrySource
  sourceId  String?
  storeId   String?
  storageZoneId String
  status    StockEntryStatus @default(PENDING)
  createdById String?
  approvedById String?
  approvedAt DateTime?
  postedAt   DateTime?
  note      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  store  Store? @relation(fields: [storeId], references: [id])
  storageZone StorageZone @relation(fields: [storageZoneId], references: [id])
  createdBy User? @relation("StockEntryCreatedBy", fields: [createdById], references: [id])
  approvedBy User? @relation("StockEntryApprovedBy", fields: [approvedById], references: [id])
  items StockEntryItem[]

  @@index([tenantId])
  @@index([storageZoneId])
  @@map("stockEntries")
}

model StockEntryItem {
  id        String   @id @default(cuid())
  tenantId  String
  stockEntryId String
  productId String
  unitId    String?
  quantity  Decimal  @db.Decimal(12, 4)
  unitCost  Decimal? @db.Decimal(12, 4)
  currencyCode String @default("USD")
  createdAt DateTime @default(now())

  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  stockEntry StockEntry @relation(fields: [stockEntryId], references: [id], onDelete: Cascade)
  product  Product @relation(fields: [productId], references: [id])
  unit     UnitOfMeasure? @relation(fields: [unitId], references: [id])

  @@index([tenantId])
  @@index([stockEntryId])
  @@map("stockEntryItems")
}

model InventoryMovement {
  id        String   @id @default(cuid())
  tenantId  String
  productId String
  storageZoneId String
  quantity  Decimal  @db.Decimal(12, 4)
  movementType InventoryMovementType
  sourceType StockEntrySource?
  sourceId  String?
  createdById String?
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])
  storageZone StorageZone @relation(fields: [storageZoneId], references: [id])
  createdBy User? @relation("InventoryMovementCreatedBy", fields: [createdById], references: [id])

  @@index([tenantId])
  @@index([storageZoneId])
  @@map("inventoryMovements")
}

model BonusRecord {
  id         String   @id @default(cuid())
  tenantId   String
  customerId String
  points     Int
  reason     String?
  createdAt  DateTime @default(now())

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer Customer @relation(fields: [customerId], references: [id])

  @@index([tenantId])
  @@map("bonusRecord")
}

model Invoice {
  id        String   @id @default(cuid())
  tenantId  String
  orderId   String?
  code      String?
  total     Decimal  @db.Decimal(10, 2)
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  order  Order? @relation(fields: [orderId], references: [id])

  @@index([tenantId])
  @@map("invoice")
}

model Bill {
  id        String   @id @default(cuid())
  tenantId  String
  code      String?
  amount    Decimal  @db.Decimal(10, 2)
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("bills")
}

model Sponsorship {
  id            String   @id @default(cuid())
  tenantId      String
  sponsorId     String
  sponsoredId   String?  @unique
  createdAt     DateTime @default(now())

  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  sponsor   Customer @relation("Sponsor", fields: [sponsorId], references: [id])
  sponsored Customer? @relation("Sponsored", fields: [sponsoredId], references: [id])

  @@index([tenantId])
  @@map("sponsorship")
}

model AuditLog {
  id        String   @id @default(cuid())
  tenantId  String
  userId    String?
  action    String
  entity    String
  entityId  String?
  meta      Json?
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User?  @relation(fields: [userId], references: [id])

  @@index([tenantId])
  @@map("auditlogs")
}

model Message {
  id          String   @id @default(cuid())
  tenantId    String
  senderId    String
  recipientId String
  content     String
  createdAt   DateTime @default(now())
  readAt      DateTime?

  tenant    Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  sender    User   @relation("MessageSender", fields: [senderId], references: [id])
  recipient User   @relation("MessageRecipient", fields: [recipientId], references: [id])

  @@index([tenantId])
  @@map("messages")
}

model Notification {
  id        String           @id @default(cuid())
  tenantId  String
  userId    String
  title     String
  message   String
  type      NotificationType @default(INFO)
  readAt    DateTime?
  createdAt DateTime         @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("notifications")
}
