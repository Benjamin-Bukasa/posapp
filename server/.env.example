DATABASE_URL="postgresql://user:password@localhost:5432/POSapp?schema=public"
# For an external managed Postgres (Render, Neon, Supabase, etc.), the URL usually needs sslmode=require
# Example: postgresql://user:password@host:5432/dbname?schema=public&sslmode=require
JWT_SECRET="change_me_access_secret"
JWT_REFRESH_SECRET="change_me_refresh_secret"
JWT_ACCESS_EXPIRES="15m"
JWT_REFRESH_DAYS="7"
GOOGLE_CLIENT_ID="your_google_client_id"
APP_URL="http://localhost:5173"
CLIENT_ORIGIN="http://localhost:5173"
COMPANY_LOGO_URL="https://your-domain.com/logo.png"
EMAIL_BANNER_URL=""
